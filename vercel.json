{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/auth(?:/.*)?",
      "dest": "/backend/server.js"
    },
    {
      "src": "/tasks(?:/.*)?",
      "dest": "/backend/server.js"
    },
    {
      "src": "/uploads(?:/.*)?",
      "dest": "/backend/server.js"
    },
    {
      "src": "/",
      "dest": "/frontend/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/public/$1"
    }
  ]
}
